{
    "name": "entelix/edilink",
    "description": "EDILink — Laravel package for building, dispatching and parsing shipping EDI messages. Pluggable carrier profiles. Zero framework coupling in the core.",
    "keywords": [
        "laravel", "edi", "shipping", "container", "logistics", "KMTC", "Adani",
        "edifact", "msc", "gate-in", "gate-out", "mnr", "depot", "HLL", "Happag Lloyd", "OOCL"
    ],
    "homepage": "https://github.com/HiralRajgor/edilink",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Entelix Technologies",
            "email": "hiralrajgor254@gmail.com",
            "homepage": "https://entelix.in",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/mail": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0|^10.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Entelix\\EdiLink\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Entelix\\EdiLink\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Entelix\\EdiLink\\EdiLinkServiceProvider"
            ],
            "aliases": {
                "EdiLink": "Entelix\\EdiLink\\Facades\\EdiLink"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
